{
  "name": "n8n-nodes-hyros",
  "version": "2.7.1",
  "description": "n8n community node for Hyros API integration with complete endpoint coverage",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "hyros",
    "attribution",
    "analytics",
    "marketing"
  ],
  "license": "MIT",
  "homepage": "https://carlosaragon.online/",
  "author": {
    "name": "Carlos Aragon",
    "email": "info@carlosaragon.online",
    "url": "https://carlosaragon.online/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CachoMX/n8n-nodes-hyros.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint --ext .ts nodes credentials && eslint package.json",
    "lintfix": "eslint --ext .ts nodes credentials --fix && eslint package.json --fix",
    "scan": "npx @n8n/scan-community-package n8n-nodes-hyros",
    "release:check": "npm run lint && npm run build && npm run scan",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.15"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/HyrosApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Hyros/Hyros.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "eslint-plugin-n8n-nodes-base": "^1.12.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "prettier": "^2.8.8",
    "typescript": "^5.0.4"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.0.0"
  }
}
