{
  "name": "n8n-nodes-hyros",
  "version": "2.0.3",
  "description": "n8n community node for Hyros API integration with complete endpoint coverage",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "hyros",
    "attribution",
    "analytics",
    "marketing"
  ],
  "license": "MIT",
  "homepage": "https://carlosaragon.online/",
  "author": {
    "name": "Carlos Aragon",
    "email": "info@carlosaragon.online",
    "url": "https://carlosaragon.online/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CachoMX/n8n-nodes-hyros.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/HyrosApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Hyros/Hyros.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "eslint-plugin-n8n-nodes-base": "^1.12.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "prettier": "^2.8.8",
    "typescript": "^5.0.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {}
}
