            },
            "trafficSource": {
              "type": "string",
              "required": false
            },
            "isDisregard": {
              "type": "boolean",
              "required": false
            },
            "isOrganic": {
              "type": "boolean",
              "required": false
            },
            "integrationType": {
              "type": "string",
              "required": false,
              "enum": [
                "FACEBOOK",
                "GOOGLE",
                "TIKTOK",
                "SNAPCHAT",
                "LINKEDIN",
                "TWITTER",
                "PINTEREST",
                "BING"
              ]
            },
            "adSourceId": {
              "type": "string",
