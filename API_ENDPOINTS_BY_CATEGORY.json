    "customCosts": {
      "description": "Create custom costs for sources",
      "endpoints": [
        {
          "name": "Create Custom Cost",
          "method": "POST",
          "path": "/api/v1.0/custom-costs",
          "bodyParameters": {
            "startDate": {
              "type": "string",
              "required": true,
              "format": "ISO 8601"
            },
            "endDate": {
              "type": "string",
              "required": false,
              "format": "ISO 8601"
            },
            "frequency": {
              "type": "string",
              "required": true,
              "enum": ["DAILY", "ONE_TIME"]
            },
            "cost": {
              "type": "number",
              "required": true,
              "min": 0.01
            },
            "tags": {
              "type": "array",
              "required": true,
              "maxItems": 10
            }
          }
        }
      ]
    },
    "clicks": {
      "description": "Track and retrieve clicks",
      "endpoints": [
        {
          "name": "Create Click",
          "method": "POST",
          "path": "/api/v1.0/clicks",
          "bodyParameters": {
            "referrerUrl": {
              "type": "string",
              "required": true
            },
            "sessionId": {
              "type": "string",
              "required": false
            },
            "previousUrl": {
              "type": "string",
              "required": false
            },
            "userAgent": {
              "type": "string",
              "required": false
            },
            "ip": {
              "type": "string",
              "required": false
            },
            "sourceLinkTag": {
              "type": "string",
              "required": false,
              "pattern": "^@"
            },
            "isOrganic": {
              "type": "boolean",
              "required": false
            },
            "integrationType": {
              "type": "string",
              "required": false,
              "enum": [
                "FACEBOOK",
                "GOOGLE",
                "TIKTOK",
                "SNAPCHAT",
                "LINKEDIN",
                "TWITTER",
                "PINTEREST",
                "BING"
              ]
            },
            "adSourceId": {
              "type": "string",
              "required": false
            },
            "adspendAdId": {
              "type": "string",
              "required": false
            },
            "adSourceClickId": {
              "type": "string",
              "required": false
            },
            "email": {
              "type": "string",
              "required": false
            },
