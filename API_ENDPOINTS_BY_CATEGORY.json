{
  "apiInfo": {
    "baseUrl": "https://api.hyros.com/v1",
    "version": "1.31",
    "authentication": {
      "type": "API-Key",
      "headerName": "API-Key",
      "location": "header"
    }
  },
  "categories": {
    "leads": {
      "description": "Manage leads and their journey",
      "endpoints": [
        {
          "name": "Retrieve Leads",
          "method": "GET",
          "path": "/api/v1.0/leads",
          "queryParameters": {
            "ids": {
              "type": "array",
              "required": false,
              "maxItems": 50,
              "description": "Array of lead ids"
            },
            "emails": {
              "type": "array",
              "required": false,
              "maxItems": 50,
              "description": "Array of emails or email prefixes"
            },
            "fromDate": {
              "type": "string",
              "required": false,
              "format": "ISO 8601",
              "description": "Filter leads from this date"
            },
            "toDate": {
              "type": "string",
              "required": false,
              "format": "ISO 8601",
              "description": "Filter leads until this date"
            },
            "pageSize": {
              "type": "number",
              "required": false,
              "min": 1,
              "max": 250,
              "description": "Maximum results per page"
            },
            "pageId": {
              "type": "string",
              "required": false,
              "description": "Next page ID for pagination"
            }
          },
          "response": {
            "result": "array",
            "nextPageId": "string",
            "request_id": "string"
          }
        },
        {
          "name": "Create Lead",
          "method": "POST",
          "path": "/api/v1.0/leads",
          "bodyParameters": {
            "email": {
              "type": "string",
              "required": false,
              "description": "Lead email (required if no phoneNumbers)"
            },
            "firstName": {
              "type": "string",
              "required": false
            },
            "lastName": {
              "type": "string",
              "required": false
            },
            "tags": {
              "type": "array",
              "required": false,
              "description": "Tags to apply to lead"
            },
            "leadIps": {
              "type": "array",
              "required": false,
              "description": "IPs for ad attribution"
            },
            "phoneNumbers": {
              "type": "array",
              "required": false,
              "description": "Phone numbers (required if no email)"
            },
            "stage": {
              "type": "string",
              "required": false,
              "description": "Stage name to apply"
            }
          }
        },
        {
          "name": "Retrieve Leads Journey",
          "method": "GET",
          "path": "/api/v1.0/leads/journey",
          "queryParameters": {
            "ids": {
              "type": "array",
              "required": true,
              "description": "Array of lead IDs"
            }
          }
        }
      ]
    },
    "sales": {
      "description": "Manage sales and revenue data",
      "endpoints": [
        {
          "name": "Retrieve Sales",
          "method": "GET",
          "path": "/api/v1.0/sales",
          "queryParameters": {
            "ids": {
              "type": "array",
              "required": false,
              "maxItems": 50
            },
            "emails": {
              "type": "array",
              "required": false,
              "maxItems": 50
            },
            "leadIds": {
              "type": "array",
              "required": false,
              "maxItems": 50
            },
            "productTags": {
              "type": "array",
              "required": false,
              "maxItems": 20
            },
            "isRecurringSale": {
              "type": "string",
              "required": false,
              "enum": ["RECURRING", "NON_RECURRING", "ALL"],
              "default": "ALL"
            },
            "saleRefundedState": {
              "type": "string",
              "required": false,
              "enum": ["REFUNDED", "NON_REFUNDED", "ALL"],
              "default": "ALL"
            },
            "fromDate": {
              "type": "string",
              "required": false,
              "format": "ISO 8601"
            },
            "toDate": {
              "type": "string",
              "required": false,
              "format": "ISO 8601"
            },
            "pageSize": {
              "type": "number",
              "required": false,
              "min": 1,
              "max": 250
            },
            "pageId": {
              "type": "string",
              "required": false
            }
          }
        },
        {
          "name": "Update Sales",
          "method": "PUT",
          "path": "/api/v1.0/sales",
          "queryParameters": {
            "ids": {
              "type": "array",
              "required": true,
              "maxItems": 50
            },
            "isRecurringSale": {
              "type": "boolean",
              "required": false
            },
            "isRefunded": {
              "type": "boolean",
              "required": false
            },
            "refundedDate": {
              "type": "string",
              "required": false,
              "format": "ISO 8601"
            },
            "refundedAmount": {
              "type": "string",
              "required": false
            }
          }
        },
        {
          "name": "Delete Sale",
          "method": "DELETE",
          "path": "/api/v1.0/sales/{id}",
          "pathParameters": {
            "id": {
              "type": "string",
              "required": true,
              "description": "Sale ID to delete"
            }
          }
        }
      ]
    },
    "orders": {
      "description": "Create and manage orders",
      "endpoints": [
        {
          "name": "Create Order",
          "method": "POST",
          "path": "/api/v1.0/orders",
          "bodyParameters": {
            "email": {
              "type": "string",
              "required": false
            },
            "parentEmail": {
              "type": "string",
              "required": false
            },
            "firstName": {
              "type": "string",
              "required": false
            },
            "lastName": {
              "type": "string",
              "required": false
            },
            "leadIps": {
              "type": "array",
              "required": false
            },
            "stage": {
              "type": "string",
              "required": false
            },
            "phoneNumbers": {
              "type": "array",
              "required": false
            },
            "orderId": {
              "type": "string",
              "required": false,
              "pattern": "^[a-zA-Z0-9_\\-.:]+$"
            },
            "externalSubscriptionId": {
              "type": "string",
              "required": false
            },
            "cartId": {
              "type": "string",
              "required": false
            },
            "date": {
              "type": "string",
              "required": false,
              "format": "ISO 8601"
            },
            "shippingCost": {
              "type": "number",
              "required": false,
              "default": 0
            },
            "taxes": {
              "type": "number",
              "required": false,
              "default": 0
            },
            "orderDiscount": {
              "type": "number",
              "required": false
            },
            "priceFormat": {
              "type": "string",
              "required": false,
              "enum": ["DECIMAL", "INTEGER"],
              "default": "DECIMAL"
            },
            "currency": {
              "type": "string",
              "required": false
            },
            "items": {
              "type": "array",
              "required": true,
              "minItems": 1,
              "items": {
                "name": {
                  "type": "string",
                  "required": true
                },
                "price": {
                  "type": "number",
                  "required": true
                },
                "externalId": {
                  "type": "string",
                  "required": false
                },
                "quantity": {
                  "type": "number",
                  "required": false,
                  "default": 1
                },
                "costOfGoods": {
                  "type": "number",
                  "required": false,
                  "default": 0
                },
                "taxes": {
                  "type": "number",
                  "required": false,
                  "default": 0
                },
                "itemDiscount": {
                  "type": "number",
                  "required": false
                },
                "packages": {
                  "type": "array",
                  "required": false
                },
                "tag": {
                  "type": "string",
                  "required": false
                },
                "categoryName": {
                  "type": "string",
                  "required": false
                }
              }
            }
          }
        },
        {
          "name": "Refund Order",
          "method": "DELETE",
          "path": "/api/v1.0/orders/{id}",
          "pathParameters": {
            "id": {
              "type": "string",
              "required": true
            }
          },
          "queryParameters": {
            "refundedAmount": {
              "type": "string",
              "required": false
            }
          }
        }
      ]
    },
    "calls": {
      "description": "Track and manage calls",
      "endpoints": [
        {
          "name": "Retrieve Calls",
          "method": "GET",
          "path": "/api/v1.0/calls",
          "queryParameters": {
            "ids": {
              "type": "array",
              "required": false,
              "maxItems": 50
            },
            "emails": {
              "type": "array",
              "required": false,
              "maxItems": 50
            },
            "leadIds": {
              "type": "array",
              "required": false,
              "maxItems": 50
            },
            "productTags": {
              "type": "array",
              "required": false,
              "maxItems": 20
            },
            "fromDate": {
              "type": "string",
              "required": false,
              "format": "ISO 8601"
            },
            "toDate": {
              "type": "string",
              "required": false,
              "format": "ISO 8601"
            },
            "pageSize": {
              "type": "number",
              "required": false,
              "min": 1,
              "max": 250
            },
            "pageId": {
              "type": "string",
              "required": false
            },
            "qualified": {
              "type": "boolean",
              "required": false
            },
            "qualificationStages": {
              "type": "array",
              "required": false,
              "maxItems": 50
            },
            "state": {
              "type": "string",
              "required": false,
              "enum": ["QUALIFIED", "UNQUALIFIED", "CANCELLED", "NO_SHOW"]
            }
          }
        },
        {
          "name": "Create Call",
          "method": "POST",
          "path": "/api/v1.0/calls",
          "bodyParameters": {
            "name": {
              "type": "string",
              "required": true
            },
            "email": {
              "type": "string",
              "required": true
            },
            "firstName": {
              "type": "string",
              "required": false
            },
            "lastName": {
              "type": "string",
              "required": false
            },
            "leadIps": {
              "type": "array",
              "required": false
            },
            "stage": {
              "type": "string",
              "required": false
            },
            "phoneNumbers": {
              "type": "array",
              "required": false
            },
            "id": {
              "type": "string",
              "required": false
            },
            "date": {
              "type": "string",
              "required": false,
              "format": "ISO 8601"
            },
            "qualified": {
              "type": "boolean",
              "required": false,
              "deprecated": true
            },
            "qualification": {
              "type": "string",
              "required": false
            },
            "state": {
              "type": "string",
              "required": false,
              "enum": ["QUALIFIED", "UNQUALIFIED", "CANCELLED", "NO_SHOW"]
            }
          }
        },
        {
          "name": "Update Calls",
          "method": "PUT",
          "path": "/api/v1.0/calls",
          "queryParameters": {
            "ids": {
              "type": "array",
              "required": true,
              "maxItems": 50
            },
            "qualification": {
              "type": "string",
              "required": false
            },
            "state": {
              "type": "string",
              "required": false,
              "enum": ["QUALIFIED", "UNQUALIFIED", "CANCELLED", "NO_SHOW"]
            },
            "qualified": {
              "type": "boolean",
              "required": false,
              "deprecated": true
            }
          }
        },
        {
          "name": "Delete Call",
          "method": "DELETE",
          "path": "/api/v1.0/calls/{id}",
          "pathParameters": {
            "id": {
              "type": "string",
              "required": true
            }
          }
        }
      ]
    },
    "attribution": {
      "description": "Get attribution reports for ads and ad accounts",
      "endpoints": [
        {
          "name": "Get Ads Attribution Report",
          "method": "GET",
          "path": "/api/v1.0/attribution",
          "queryParameters": {
            "attributionModel": {
              "type": "string",
              "required": true,
              "enum": ["last_click", "scientific", "first_click"]
            },
            "startDate": {
              "type": "string",
              "required": true,
              "format": "ISO 8601"
            },
            "endDate": {
              "type": "string",
              "required": true,
              "format": "ISO 8601"
            },
            "level": {
              "type": "string",
              "required": true,
              "enum": [
                "google_campaign",
                "google_v2_adgroup",
                "google_ad",
                "google_v2_keyword",
                "facebook_adset",
                "tiktok_adgroup",
                "snapchat_adsquad",
                "pinterest_adgroup",
                "twitter_adgroup",
                "bing_adgroup",
                "linkedin_campaign",
                "facebook_ad",
                "tiktok_ad",
                "snapchat_ad",
                "pinterest_ad",
                "bing_ad"
              ]
            },
            "fields": {
              "type": "string",
              "required": true,
              "description": "Comma-separated list of metrics"
            },
            "ids": {
              "type": "string",
              "required": true,
              "description": "Comma-separated IDs"
            },
            "keywordsIds": {
              "type": "string",
              "required": false
            },
            "currency": {
              "type": "string",
              "required": false,
              "enum": ["user_currency", "usd"],
              "default": "user_currency"
            },
            "dayOfAttribution": {
              "type": "boolean",
              "required": false,
              "default": false
            },
            "scientificDaysRange": {
              "type": "number",
              "required": false,
              "min": 1,
              "max": 30,
              "default": 30
            },
            "sourceConfiguration": {
              "type": "string",
              "required": false,
              "enum": [
                "all_sources",
                "only_organic",
                "only_paid",
                "prioritize_organic",
                "prioritize_paid"
              ]
            },
            "ignoreRecurringSales": {
              "type": "boolean",
              "required": false,
              "default": false
            },
            "isAdAccountId": {
              "type": "boolean",
              "required": false,
              "default": false
            },
            "forecastingOption": {
              "type": "string",
              "required": false,
              "enum": ["first_sale", "total_sales"],
              "default": "first_sale"
            },
            "windowAttributionDaysRange": {
              "type": "number",
              "required": false,
              "min": 0,
              "max": 365,
              "default": 0
            },
            "newCustomerConfiguration": {
              "type": "string",
              "required": false,
              "enum": [
                "all_customers",
                "only_returning_customers",
                "only_unique_customers"
              ],
              "default": "all_customers"
            }
          }
        },
        {
          "name": "Get Ad Accounts Attribution Report",
          "method": "GET",
          "path": "/api/v1.0/attribution/ad-account",
          "queryParameters": {
            "attributionModel": {
              "type": "string",
              "required": true,
              "enum": ["last_click", "scientific", "first_click"]
            },
            "startDate": {
              "type": "string",
              "required": true,
              "format": "ISO 8601"
            },
            "endDate": {
              "type": "string",
              "required": true,
              "format": "ISO 8601"
            },
            "fields": {
              "type": "string",
              "required": true
            },
            "ids": {
              "type": "string",
              "required": true,
              "description": "Single Ad Account ID only"
            },
            "currency": {
              "type": "string",
              "required": false,
              "enum": ["user_currency", "usd"],
              "default": "user_currency"
            },
            "dayOfAttribution": {
              "type": "boolean",
              "required": false,
              "default": false
            },
            "scientificDaysRange": {
              "type": "number",
              "required": false,
              "min": 1,
              "max": 30,
              "default": 30
            },
            "sourceConfiguration": {
              "type": "string",
              "required": false,
              "enum": [
                "all_sources",
                "only_organic",
                "only_paid",
                "prioritize_organic",
                "prioritize_paid"
              ]
            },
            "dateTimeGroupingOption": {
              "type": "string",
              "required": false,
              "enum": ["ad_account", "day", "week", "month", "year"],
              "default": "ad_account"
            },
            "ignoreRecurringSales": {
              "type": "boolean",
              "required": false,
              "default": false
            },
            "forecastingOption": {
              "type": "string",
              "required": false,
              "enum": ["first_sale", "total_sales"],
              "default": "first_sale"
            },
            "windowAttributionDaysRange": {
              "type": "number",
              "required": false,
              "min": 0,
              "max": 365,
              "default": 0
            },
            "newCustomerConfiguration": {
              "type": "string",
              "required": false,
              "enum": [
                "all_customers",
                "only_returning_customers",
                "only_unique_customers"
              ],
              "default": "all_customers"
            }
          }
        }
      ]
    },
